<Window x:Class="MedicalAnalyzer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MedicalAnalyzer.App"
        mc:Ignorable="d"
        Title="医療分析装置"
        Height="650"
        Width="1000"
        MinWidth="800"
        MinHeight="500"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#F3F6F9">

        <!--页面纵向分为三块-->
        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition Height="*" />
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>

        <!--顶部区域-->
        <Border Grid.Row="0"
                Background="#16324F"
                Padding="24,0">

            <Grid>

                <!--应用标题-->
                <TextBlock Text="医療分析装置"
                           Foreground="White"
                           FontSize="26"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />

                <!--设备状态-->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">

                    <!--图形控件-->
                    <Ellipse Width="12"
                             Height="12"
                             Fill="#45C486"
                             Margin="0,0,8,0" />

                    <TextBlock Text="待機中"
                               Foreground="White"
                               FontSize="16"
                               VerticalAlignment="Center" />

                </StackPanel>

            </Grid>

        </Border>


        <!--中部区域-->
        <Grid Grid.Row="1"
              Margin="24">

            <!--左侧操作区、间隔、右侧内容区-->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>


            <!--左侧操作面板-->

            <!--Border标签内部只能存在一个元素，多元素需要StackPanel-->
            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="8"
                    Padding="20">

                <StackPanel>

                    <TextBlock Text="装置操作"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,20" />

                    <Button Content="検体登録"
                            Height="44"
                            Margin="0,0,0,12" />

                    <Button Content="測定開始"
                            Height="44"
                            Margin="0,0,0,12" />

                    <Button Content="測定停止"
                            Height="44"
                            IsEnabled="False" />

                </StackPanel>

            </Border>

            <!-- 检体列表面板 -->
            <Border Grid.Column="2"
                    Background="White"
                    CornerRadius="8"
                    Padding="20">

                <StackPanel>

                    <TextBlock Text="検体一覧"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,16" />

                    <TextBlock Text="登録された検体はありません"
                               Foreground="#667085"
                               FontSize="16" />

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Samples}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="検体ID"
                                                Binding="{Binding Id}"
                                                Width="110" />

                            <DataGridTextColumn Header="検査項目"
                                                Binding="{Binding TestItem}"
                                                Width="*" />

                            <DataGridTextColumn Header="登録時刻"
                                                Binding="{Binding RegisteredAt,
                                                      StringFormat={}{0:HH:mm}}"
                                                Width="120" />

                            <DataGridTextColumn Header="進捗"
                                                Binding="{Binding Progress,
                                                      StringFormat={}{0}%}"
                                                Width="80" />
                        </DataGrid.Columns>
                    </DataGrid>

                </StackPanel>

            </Border>

        </Grid>


        <!--底部状态栏-->

        <Border Grid.Row="2"
                Background="#E4EAF0"
                Padding="24,0">

            <TextBlock Text="システム準備完了"
                       Foreground="#344054"
                       FontSize="14"
                       VerticalAlignment="Center" />
        </Border>

    </Grid>

</Window>
